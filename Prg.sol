/* Container Query support for ViewPlugin */

/* This makes layouts respond to container width instead of viewport width */

.qd-container {
  container-type: inline-size;
  container-name: qd-main;
}

/* Default: stacked layout for narrow container */

.qd-grid-col,
.qd-card-col {
  width: 100% !important;
  flex: 0 0 100% !important;
  max-width: 100% !important;
}

.qd-header {
  flex-direction: column;
  align-items: flex-start !important;
}

.qd-header-buttons {
  flex-direction: column;
  width: 100%;
  margin-top: 0.75rem;
}

.qd-filter-bar {
  flex-direction: column;
}

/* Wide container (>= 600px): side-by-side layout */

@container qd-main (min-width: 600px) {
  .qd-grid-col {
    width: 50% !important;
    flex: 0 0 50% !important;
    max-width: 50% !important;
  }
  
  .qd-card-col {
    width: 50% !important;
    flex: 0 0 50% !important;
    max-width: 50% !important;
  }
  
  .qd-header {
    flex-direction: row;
    align-items: center !important;
  }
  
  .qd-header-buttons {
    flex-direction: row;
    width: auto;
    margin-top: 0;
  }
  
  .qd-filter-bar {
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
  }
}

/* Extra wide container (>= 900px): 3-column layout for cards */

@container qd-main (min-width: 900px) {
  .qd-card-col {
    width: 33.333% !important;
    flex: 0 0 33.333% !important;
    max-width: 33.333% !important;
  }
}

/* EditHtmlTemplate layout - default: stacked so controls keep a usable width. */

.qd-main-col,
.qd-side-col {
  width: 100% !important;
  flex: 0 0 100% !important;
  max-width: 100% !important;
  padding-right: 0 !important;
  margin-bottom: 1rem;
}

.qd-side-col > .flex-shrink-0 {
  width: 100%;
}

/* EditHtmlTemplate layout - side-by-side only when the controls can stay readable. */


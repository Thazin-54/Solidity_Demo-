</style><style>/* ========================================
   Notification Bell & Dropdown Styles
   Uses --bs-* and --custom-* theme variables
   to match the app's current theme (dark/light).
   ======================================== */

.notification-bell-container {
  position: relative;
  display: inline-flex;
  align-items: center;
}

.notification-bell-icon {
  position: relative;
  font-size: 1rem;
  cursor: pointer;
  color: var(--bs-body-color, #a2a3bd);
  padding: 4px 8px;
  transition: opacity 0.15s ease;
}

.notification-bell-icon:hover {
  opacity: 0.8;
}

.notification-badge {
  position: absolute;
  top: 0;
  right: 2px;
  background: var(--bs-danger, #e74c3c);
  color: #fff;
  font-size: 0.6rem;
  font-weight: 700;
  min-width: 16px;
  height: 16px;
  line-height: 16px;
  text-align: center;
  border-radius: 10px;
  padding: 0 4px;
  pointer-events: none;
}

/* ---- Dropdown Panel ---- */

.notification-dropdown {
  position: absolute;
  top: calc(100% + 8px);
  right: 0;
  width: 380px;
  max-height: 480px;
  background-color: var(--bs-secondary-bg, #333446);
  border: 1px solid var(--bs-border-color, #3f4455);
  border-radius: 8px;
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.35);
  z-index: 10000;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  color: var(--bs-body-color, #a2a3bd);
}

.notification-dropdown-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 16px;
  border-bottom: 1px solid var(--bs-border-color, #3f4455);
  flex-shrink: 0;
}

.notification-dropdown-title {
  font-weight: 600;
  font-size: 0.95rem;
  color: var(--bs-emphasis-color, #fff);
}

.notification-mark-all-btn {
  background: none;
  border: none;
  color: var(--custom-primary, #64c4ff);
  font-size: 0.75rem;
  cursor: pointer;
  padding: 2px 8px;
  border-radius: 4px;
  transition: background 0.15s ease;
}

.notification-mark-all-btn:hover {
  background: var(--bs-body-bg, #222336);
}

/* ---- Scrollable Body ---- */

.notification-dropdown-body {
  overflow-y: auto;
  flex: 1;
  min-height: 80px;
}

/* ---- Empty / Loading States ---- */

.notification-empty,
.notification-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 32px 16px;
  color: var(--bs-secondary-color, rgba(222,226,230,0.75));
  font-size: 0.85rem;
}

/* ---- Individual Notification Item ---- */

.notification-item {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  padding: 12px 16px;
  border-bottom: 1px solid var(--bs-border-color, #3f4455);
  cursor: pointer;
  transition: background-color 0.15s ease;
  position: relative;
}

.notification-item:hover {
  background-color: var(--bs-body-bg, #222336);
}

.notification-item:last-child {
  border-bottom: none;
}

.notification-unread {
  background-color: var(--custom-onsurface-layer-1, #2a2c3f);
}

.notification-priority-critical {
  border-left: 3px solid var(--bs-danger, #e74c3c);
}

.notification-priority-high {
  border-left: 3px solid var(--bs-warning, #f39c12);
}

/* ---- Icon ---- */

.notification-icon-primary {
  color: var(--custom-primary, #64c4ff);
}

.notification-item-icon {
  flex-shrink: 0;
  width: 28px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1rem;
  margin-top: 2px;
}

/* ---- Content ---- */

.notification-item-content {
  flex: 1;
  min-width: 0;
}

.notification-item-header {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 2px;
}

.notification-item-title {
  font-size: 0.82rem;
  color: var(--bs-body-color, #a2a3bd);
  line-height: 1.3;
  flex: 1;
  min-width: 0;
}

.notification-item-time {
  font-size: 0.7rem;
  color: var(--bs-tertiary-color, rgba(255,255,255,0.5));
  white-space: nowrap;
  flex-shrink: 0;
}

.notification-item-body {
  font-size: 0.78rem;
  color: var(--bs-secondary-color, rgba(222,226,230,0.75));
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 4px;
}

.notification-item-actions {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-top: 4px;
}

.notification-action-btn {
  background: var(--custom-primary);
  color: var(--bs-body-bg);
  border: none;
  border-radius: 4px;
  font-size: 0.7rem;
  padding: 2px 10px;
  cursor: pointer;
  transition: opacity 0.15s ease;
}

.notification-action-btn:hover {
  opacity: 0.85;
}

.notification-action-invitation {
  background: var(--bs-success, #27ae60);
}

.notification-action-feedback_form {
  background: var(--custom-primary);
}

.notification-dismiss-btn {
  background: none;
  border: none;
  color: var(--bs-tertiary-color, rgba(255,255,255,0.5));
  font-size: 0.75rem;
  cursor: pointer;
  padding: 4px 6px;
  align-self: flex-start;
  flex-shrink: 0;
  transition: color 0.15s ease;
}

.notification-dismiss-btn:hover {
  color: var(--bs-body-color, #a2a3bd);
}

/* ---- Unread Dot ---- */

.notification-unread-dot {
  flex-shrink: 0;
  width: 8px;
  height: 8px;
  background: var(--custom-primary, #64c4ff);
  border-radius: 50%;
}

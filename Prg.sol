/* ============================
   Nudge Decorations
   Pulsating dots, glowing borders, tooltips
   ============================ */

/* Default nudge color — overridable via --nudge-color on the element */

.nudge-decoration {
  --nudge-color: #6366f1;
}

/* Glow effect around decorated element */

.nudge-decoration--glow {
  border-radius: 4px;
  box-shadow: 0 0 0 2px color-mix(in srgb, var(--nudge-color) 50%, transparent),
              0 0 12px color-mix(in srgb, var(--nudge-color) 30%, transparent);
  animation: nudge-glow-pulse 2s ease-in-out infinite;
}

@keyframes nudge-glow-pulse {
  0%, 100% { box-shadow: 0 0 0 2px color-mix(in srgb, var(--nudge-color) 50%, transparent),
                          0 0 12px color-mix(in srgb, var(--nudge-color) 30%, transparent); }
  50% { box-shadow: 0 0 0 3px color-mix(in srgb, var(--nudge-color) 70%, transparent),
                     0 0 20px color-mix(in srgb, var(--nudge-color) 50%, transparent); }
}

/* Pulsating dot */

.nudge-pulse-dot {
  position: absolute;
  top: -4px;
  right: -4px;
  width: 12px;
  height: 12px;
  border-radius: 50%;
  background: var(--nudge-color, #6366f1);
  cursor: pointer;
  z-index: 1;
  animation: nudge-dot-pulse 1.5s ease-in-out infinite;
}

.nudge-pulse-dot::after {
  content: '';
  position: absolute;
  inset: -4px;
  border-radius: 50%;
  background: color-mix(in srgb, var(--nudge-color, #6366f1) 30%, transparent);
  animation: nudge-dot-ring 1.5s ease-in-out infinite;
}

@keyframes nudge-dot-pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.15); }
}

@keyframes nudge-dot-ring {
  0%, 100% { transform: scale(1); opacity: 0.3; }
  50% { transform: scale(1.8); opacity: 0; }
}

/* Badge decoration */

.nudge-decoration--badge::after {
  content: '!';
  position: absolute;
  top: -6px;
  right: -6px;
  width: 16px;
  height: 16px;
  border-radius: 50%;
  background: #6366f1;
  color: #fff;
  font-size: 0.6rem;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1;
  pointer-events: auto;
}

/* Tooltip */

.nudge-tooltip {
  position: absolute;
  top: -8px;
  right: 20px;
  transform: translateY(-100%);
  background: var(--custom-onsurface-layer-2, #1a1a2e);
  color: var(--bs-body-color, #e2e2e2);
  border: 1px solid var(--bs-border-color, rgba(255, 255, 255, 0.1));
  border-radius: 8px;
  padding: 0.5rem 0.75rem;
  font-size: 0.75rem;
  line-height: 1.4;
  max-width: 220px;
  white-space: normal;
  box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3);
  pointer-events: auto;
  z-index: 2;
  animation: nudge-tooltip-in 0.15s ease-out;
}

.nudge-tooltip::after {
  content: '';
  position: absolute;
  bottom: -5px;
  right: 12px;
  width: 10px;
  height: 10px;
  background: var(--custom-onsurface-layer-2, #1a1a2e);
  border-right: 1px solid var(--bs-border-color, rgba(255, 255, 255, 0.1));
  border-bottom: 1px solid var(--bs-border-color, rgba(255, 255, 255, 0.1));
  transform: rotate(45deg);
}

@keyframes nudge-tooltip-in {
  from { opacity: 0; transform: translateY(calc(-100% + 4px)); }
  to { opacity: 1; transform: translateY(-100%); }
}

/* Right-side variant */

.nudge-widget--right {
  left: auto;
  right: 16px;
  animation-name: nudge-slideIn-right;
}

@keyframes nudge-slideIn-right {
  from {
    opacity: 0;
    transform: translateY(30px) scale(0.95);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

.nudge-widget--right.nudge-widget--out {
  transform: translateY(20px) scale(0.95);
}

/* Responsive — hide on very small screens */

@media (max-width: 600px) {
  .nudge-widget {
    display: none;
  }
}

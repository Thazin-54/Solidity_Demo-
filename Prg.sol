}

[data-theme="dark"] .chat-history-sidebar .btn-link,
body.dark .chat-history-sidebar .btn-link {
  color: #a0a0b0 !important;
}

[data-theme="dark"] .chat-history-sidebar .btn-primary,
body.dark .chat-history-sidebar .btn-primary {
  background-color: #4a9eff !important;
  /* border-color: #4a9eff !important; */
}

[data-theme="dark"] .chat-history-sidebar .form-control,
body.dark .chat-history-sidebar .form-control {
  background-color: #2a2a3a !important;
  /* border-color: #3a3a4a !important; */
  color: #e0e0e0 !important;
}

[data-theme="dark"] .chat-history-sidebar .input-group-text,
body.dark .chat-history-sidebar .input-group-text {
  background-color: #2a2a3a !important;
  /* border-color: #3a3a4a !important; */
  color: #a0a0b0 !important;
}

[data-theme="dark"] .chat-history-sidebar .btn-secondary,
body.dark .chat-history-sidebar .btn-secondary {
  background-color: #3a3a4a !important;
  /* border-color: #4a4a5a !important; */
  color: #e0e0e0 !important;
}

[data-theme="dark"] .chat-history-sidebar .btn-outline-secondary,
body.dark .chat-history-sidebar .btn-outline-secondary {
  /* border-color: #4a4a5a !important; */
  color: #a0a0b0 !important;
}

[data-theme="dark"] .chat-history-sidebar .btn-outline-secondary:hover,
body.dark .chat-history-sidebar .btn-outline-secondary:hover {
  background-color: #3a3a4a !important;
  color: #e0e0e0 !important;
}

[data-theme="dark"] .chat-history-sidebar .conversation-item,
body.dark .chat-history-sidebar .conversation-item {
  background-color: #262637 !important;
  /* border: 1px solid #3a3a4a; */
  color: #e0e0e0 !important;
}

[data-theme="dark"] .chat-history-sidebar .conversation-item:hover,
body.dark .chat-history-sidebar .conversation-item:hover {
  background-color: #2e2e3e !important;
}

[data-theme="dark"] .chat-history-sidebar .conversation-item.active,
body.dark .chat-history-sidebar .conversation-item.active {
  background-color: #4a9eff !important;
  color: #ffffff !important;
}

[data-theme="dark"] .chat-history-sidebar .conversation-item .text-muted,
body.dark .chat-history-sidebar .conversation-item .text-muted {
  color: #a0a0b0 !important;

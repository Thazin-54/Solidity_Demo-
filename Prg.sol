  margin: 6px 0 0;
  padding: 4px 10px;
  border-radius: var(--bs-border-radius-pill);
  background: color-mix(in srgb, var(--bs-success) 12%, transparent);
  border: 1px solid color-mix(in srgb, var(--bs-success) 30%, transparent);
  color: var(--bs-success);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.01em;
  width: -moz-fit-content;
  width: fit-content;
}

.pm-plan__savings i {
  font-size: 10px;
  color: var(--bs-success);
}

/* Subtler nudge shown on the *monthly* tab — clickable, switches to yearly. */

.pm-plan__savings-tease {
  -moz-appearance: none;
       appearance: none;
  background: transparent;
  border: 0;
  padding: 6px 0 0;
  display: inline-flex;
  align-items: center;
  gap: 6px;
  color: var(--bs-body-color);
  font-size: 11px;
  font-weight: 500;
  cursor: pointer;
  text-align: left;
}

.pm-plan__savings-tease:hover {
  color: var(--bs-purple);
  text-decoration: underline;
}

.pm-plan__savings-tease i {
  font-size: 9px;
}

/* Quieter price headline — used by promo / contact rows where there's no
   dollar amount to anchor on. */

.pm-plan__price-num--quiet {
  font-weight: 600;
  letter-spacing: -0.01em;
}

/* Team / Enterprise one-liner. Lives inside the .pm-plans grid but spans
   the full width so it reads as a footer row, not another tier. */

.pm-enterprise-strip {
  grid-column: 1 / -1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  margin-top: 4px;
  padding: 12px 18px;
  border-radius: var(--bs-border-radius-lg);
  border: 1px solid var(--bs-border-color);
  background: var(--custom-onsurface-layer-1);
  color: var(--bs-body-color);
  text-decoration: none;
  transition: background 120ms ease, border-color 120ms ease;
}

.pm-enterprise-strip:hover {
  text-decoration: none;
  border-color: var(--custom-border-light);
  background: var(--custom-onsurface-layer-2);
}

.pm-enterprise-strip__label {
  display: inline-flex;
  align-items: baseline;
  gap: 10px;
  flex-wrap: wrap;
  font-size: 13px;
}

.pm-enterprise-strip__label i {
  color: var(--custom-primary);
  align-self: center;
}

.pm-enterprise-strip__sub {
  color: var(--bs-secondary-color);
  font-size: 12px;
}

.pm-enterprise-strip__cta {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 12px;
  font-weight: 600;
  color: var(--custom-primary);
  white-space: nowrap;
}

.pm-plan {
  position: relative;
  background: var(--bs-secondary-bg);
  border: 0.5px solid var(--bs-border-color);
  border-radius: var(--bs-border-radius-lg);
  padding: 26px 22px 22px;
  display: flex;
  flex-direction: column;
  gap: 18px;
  transition: border-color .2s ease;
}

.pm-plan:not(.is-current):not(.is-free):hover {
  border-color: color-mix(in srgb, var(--custom-primary) 50%, transparent);
}

.pm-plan.is-current {
  cursor: default;
  background: color-mix(in srgb, var(--custom-primary) 6%, var(--bs-secondary-bg));
  border-color: color-mix(in srgb, var(--custom-primary) 60%, transparent);
}

.pm-plan.is-free {
  cursor: default;
}

.pm-plan.is-free:not(.is-current) {
  opacity: 0.5;
}

.pm-plan.is-free:not(.is-current) .pm-plan__btn {
  opacity: 1;
}

.pm-plan.is-recommended {
  background: color-mix(in srgb, var(--custom-primary) 4%, var(--bs-secondary-bg));
  border-color: color-mix(in srgb, var(--custom-primary) 45%, transparent);
}

.pm-plan__current {
  position: absolute;
  top: 14px;
  right: 14px;
  font-family: var(--bs-font-sans-serif);
  font-size: 9px;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  padding: 4px 9px;
  border-radius: 4px;
}

.pm-plan__ribbon {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  align-self: flex-start;
  font-family: var(--bs-font-sans-serif);
  font-size: 11px;
  font-weight: 600;
  padding: 4px 10px;
  border-radius: var(--bs-border-radius-sm);
  background: color-mix(in srgb, var(--custom-primary) 12%, transparent);
  border: 0.5px solid color-mix(in srgb, var(--custom-primary) 40%, transparent);
  color: var(--custom-primary);
}

.pm-plan__ribbon i { font-size: 9px; }

.pm-plan__current {
  background: color-mix(in srgb, var(--custom-primary) 18%, transparent);
  border: 0.5px solid color-mix(in srgb, var(--custom-primary) 50%, transparent);
  color: var(--custom-primary);
}

.pm-plan__name {
  font-family: var(--bs-font-sans-serif);
  font-weight: 600;
  font-size: 18px;
  letter-spacing: -0.01em;
  line-height: 1.1;
}

.pm-plan__tag {
  font-size: 12px;
  color: var(--bs-body-color);
  margin-top: 6px;
  line-height: 1.5;
}

.pm-plan__price {
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
  gap: 8px;
  row-gap: 2px;
  padding: 14px 0 2px;
  border-top: 0.5px solid var(--bs-border-color);
}

.pm-plan__price-num {
  font-family: var(--bs-font-sans-serif);
  font-weight: 600;
  font-size: 32px;
  line-height: 1;
  letter-spacing: -0.03em;
  color: var(--bs-heading-color);
  font-variant-numeric: tabular-nums;
}

.pm-plan__price-cad {
  font-family: var(--bs-font-sans-serif);
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--bs-secondary-color);
}

.pm-plan__features {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 10px;
  flex: 1;
}

.pm-plan__features li {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  font-size: 13px;
  color: var(--bs-heading-color);
  line-height: 1.5;
}

.pm-plan__features i {
  flex-shrink: 0;
  margin-top: 3px;
  font-size: 10px;
  color: var(--custom-primary);
}

.pm-plan__btn {
  margin-top: 6px;
  padding: 12px 16px;
  border-radius: var(--bs-border-radius);
  border: 1px solid var(--bs-border-color);
  background: var(--custom-onsurface-layer-2);
  color: var(--bs-body-color);
  font-family: var(--bs-font-sans-serif);
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
  transition: background .2s ease, border-color .2s ease, color .2s ease;
}

.pm-plan__btn:hover:not(.is-disabled) {
  background: var(--custom-primary);
  border-color: var(--custom-primary);
  color: var(--bs-body-bg);
}

.pm-plan__btn.is-disabled {
  cursor: default;
  opacity: 0.5;
  background: transparent;
}

/* Cancel link — quiet text-button under the active paid plan card. */

.pm-plan__cancel-link {
  margin-top: 8px;
  padding: 6px 4px;
  background: transparent;
  border: 0;
  color: var(--bs-body-color);
  font-family: var(--bs-font-sans-serif);
  font-size: 12px;
  font-weight: 500;
  text-align: center;
  cursor: pointer;
  text-decoration: underline;
  text-decoration-color: color-mix(in srgb, var(--bs-body-color) 40%, transparent);
  text-underline-offset: 3px;
  transition: color .15s ease;
}

.pm-plan__cancel-link:hover {
  color: var(--bs-danger);
}

/* "Active until {date} — will not renew" notice on the active card. */

.pm-plan__cancel-notice {
  margin-top: 10px;
  padding: 8px 10px;
  border-radius: 8px;
  background: color-mix(in srgb, var(--bs-warning) 10%, transparent);
  border: 1px solid color-mix(in srgb, var(--bs-warning) 30%, transparent);
  color: var(--bs-warning);
  font-family: var(--bs-font-sans-serif);
  font-size: 12px;
  font-weight: 500;
  display: flex;
  gap: 8px;
  align-items: center;
}

.pm-plan__cancel-notice i {
  flex: none;
  font-size: 13px;
}

/* Badges container — children are position:absolute so this must not
   participate in the flex column layout, otherwise it adds an empty gap. */

.pm-plan__badges {
  display: contents;
}

/* Access badge variants */

.pm-plan__current--access {
  background: color-mix(in srgb, var(--bs-success) 18%, transparent);
  border-color: color-mix(in srgb, var(--bs-success) 50%, transparent);
  color: var(--bs-success);
}

/* Head groups name + description without extra spacing */

.pm-plan__head {
  display: flex;
  flex-direction: column;
}

/* Trial badge — "X-day free trial" chip */

.pm-plan__trial-badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  align-self: flex-start;
  padding: 4px 10px;
  border-radius: var(--bs-border-radius-sm);
  background: color-mix(in srgb, var(--bs-success) 12%, transparent);
  border: 0.5px solid color-mix(in srgb, var(--bs-success) 30%, transparent);
  color: var(--bs-success);
  font-size: 11px;
  font-weight: 600;
}

.pm-plan__trial-badge i { font-size: 10px; }

/* Strikethrough original price when an intro discount applies. Takes its own
   line so the larger discounted price has full card width — important for
   longer non-$ currency strings (e.g. "THB 666.88", "CLP 18,393"). */

.pm-plan__price-was {
  flex-basis: 100%;
  font-size: 18px;
  font-variant-numeric: tabular-nums;
  color: var(--bs-secondary-color);
  text-decoration: line-through;
  text-decoration-color: var(--bs-secondary-color);
}

/* Intro discount promo badge ("60% off first 3 months") */

.pm-plan__intro-offer {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  align-self: flex-start;
  padding: 4px 10px;
  border-radius: var(--bs-border-radius-sm);
  background: color-mix(in srgb, var(--bs-warning) 12%, transparent);
  border: 0.5px solid color-mix(in srgb, var(--bs-warning) 30%, transparent);
  color: var(--bs-warning);
  font-size: 11px;
  font-weight: 600;
}

.pm-plan__intro-offer i { font-size: 10px; }

/* Intro credits line ("X free AI credits included") */

.pm-plan__intro-credits {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  align-self: flex-start;
  font-size: 12px;
  font-weight: 500;
  color: var(--bs-success);
}

.pm-plan__intro-credits i { font-size: 11px; }

/* Reactivate link — mirrors cancel-link but green on hover */

.pm-plan__reactivate-link {
  margin-top: 8px;
  padding: 6px 4px;
  background: transparent;
  border: 0;
  color: var(--bs-body-color);
  font-family: var(--bs-font-sans-serif);
  font-size: 12px;
  font-weight: 500;
  text-align: center;
  cursor: pointer;
  text-decoration: underline;
  text-decoration-color: color-mix(in srgb, var(--bs-body-color) 40%, transparent);
  text-underline-offset: 3px;
  transition: color .15s ease;
}

.pm-plan__reactivate-link:hover { color: var(--bs-success); }

.pm-plan__reactivate-link i { font-size: 11px; margin-right: 4px; }

/* ─── Confirm modal ───────────────────────────────────────────────────── */

.pm-modal__backdrop {
  position: absolute;
  inset: 0;
  z-index: 100;
  display: grid;
  place-items: center;
  padding: 24px;
  background: rgba(0, 0, 0, 0.5);
  backdrop-filter: blur(10px) saturate(120%);
  animation: pm-modal-fade .18s ease-out;
}

@keyframes pm-modal-fade {
  from { opacity: 0; }
  to   { opacity: 1; }
}

.pm-modal {
  position: relative;
  width: 100%;
  max-width: 500px;
  background: var(--bs-body-bg);
  border: 1px solid var(--bs-border-color);
  border-radius: var(--bs-border-radius-lg);
  box-shadow: var(--bs-box-shadow-lg);
  font-family: var(--bs-font-sans-serif);
  color: var(--bs-body-color);
  overflow: hidden;
  animation: pm-modal-pop .15s ease-out;
  --pm-modal-accent: var(--custom-primary);
}

.pm-modal--danger {
  --pm-modal-accent: var(--bs-danger);
  border-color: color-mix(in srgb, var(--bs-danger) 30%, transparent);
}

.pm-modal__atmosphere {
  display: none;
}

.pm-modal__atmosphere-orb {
  position: absolute;
  top: -40%;
  left: 50%;
  transform: translateX(-50%);
  width: 120%;
  aspect-ratio: 1 / 1;
  background: radial-gradient(circle at center, color-mix(in srgb, var(--pm-modal-accent) 35%, transparent) 0%, transparent 60%);
  opacity: 0.55;
  filter: blur(20px);
}

.pm-modal__atmosphere-grain {
  position: absolute;
  inset: 0;
  background-image: radial-gradient(rgba(255,255,255,0.025) 1px, transparent 1px);
  background-size: 3px 3px;
  opacity: 0.4;
  mix-blend-mode: overlay;
}

@keyframes pm-modal-pop {
  from { transform: translateY(12px) scale(0.97); opacity: 0; }
  to   { transform: none; opacity: 1; }
}

.pm-modal > *:not(.pm-modal__atmosphere) {
  position: relative;
  z-index: 1;
}

.pm-modal__header {
  display: flex;
  align-items: flex-start;
  gap: 16px;
  padding: 28px 28px 12px;
}

.pm-modal__icon {
  flex: none;
  width: 52px;
  height: 52px;
  border-radius: var(--bs-border-radius-lg);
  display: grid;
  place-items: center;
  font-size: 22px;
  color: var(--pm-modal-accent);
  background: color-mix(in srgb, var(--pm-modal-accent) 12%, transparent);
  border: 0.5px solid color-mix(in srgb, var(--pm-modal-accent) 40%, transparent);
  box-shadow:
    0 0 0 6px color-mix(in srgb, var(--pm-modal-accent) 8%, transparent),
    0 8px 24px -8px color-mix(in srgb, var(--pm-modal-accent) 55%, transparent);
}

.pm-modal__heading {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6px;
  padding-top: 4px;
}

.pm-modal__eyebrow {
  font-family: var(--bs-font-sans-serif);
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--bs-secondary-color);
}

.pm-modal__title {
  margin: 0;
  font-family: var(--bs-font-sans-serif);
  font-weight: 600;
  font-size: 20px;
  letter-spacing: -0.02em;
  line-height: 1.25;
  color: var(--bs-heading-color);
}

.pm-modal__close {
  position: absolute;
  top: 14px;
  right: 14px;
  z-index: 2;
  width: 30px;
  height: 30px;
  border-radius: 10px;
  border: 1px solid var(--bs-border-color);
  background: transparent;
  color: var(--bs-body-color);
  cursor: pointer;
  display: grid;
  place-items: center;
  font-size: 12px;
  transition: background .15s ease;
}

.pm-modal__close:hover {
  background: var(--custom-onsurface-layer-2);
  color: var(--bs-heading-color);
}

.pm-modal__body {
  padding: 4px 28px 18px;
  font-size: 13.5px;
  line-height: 1.6;
  color: var(--bs-body-color);
}

.pm-modal__body p {
  margin: 0 0 8px;
}

.pm-modal__body p:last-child {
  margin-bottom: 0;
}

/* Highlights row — proration / from→to chips */

.pm-modal__highlights {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  padding: 6px 28px 18px;
}

.pm-modal__highlight {
  flex: 1 1 130px;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4px;
  padding: 12px 14px;
  border-radius: var(--bs-border-radius-lg);
  background: var(--custom-onsurface-layer-2);
  border: 1px solid var(--bs-border-color);
}

.pm-modal__highlight-label {
  font-family: var(--bs-font-sans-serif);
  font-size: 9.5px;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--bs-secondary-color);
}

.pm-modal__highlight-value {
  font-family: var(--bs-font-sans-serif);
  font-size: 14px;
  font-weight: 600;
  letter-spacing: -0.01em;
  color: var(--bs-heading-color);
  word-break: break-word;
}

.pm-modal__highlight--positive {
  background: color-mix(in srgb, var(--custom-primary) 9%, transparent);
  border-color: color-mix(in srgb, var(--custom-primary) 35%, transparent);
}

.pm-modal__highlight--positive .pm-modal__highlight-value { color: var(--custom-primary); }

.pm-modal__highlight--negative {
  background: color-mix(in srgb, var(--bs-danger) 9%, transparent);
  border-color: color-mix(in srgb, var(--bs-danger) 35%, transparent);
}

.pm-modal__highlight--negative .pm-modal__highlight-value { color: var(--bs-danger); }

.pm-modal__highlight--muted {
  opacity: 0.78;
}

.pm-modal__actions {
  display: flex;
  flex-direction: column;
  gap: 8px;
  padding: 4px 24px 22px;
}

@media (min-width: 520px) {
  .pm-modal__actions {
    flex-direction: row-reverse;
    justify-content: flex-start;
    flex-wrap: wrap;
    padding: 4px 28px 24px;
  }
}

.pm-modal__btn {
  -moz-appearance: none;
       appearance: none;
  border: 1px solid var(--bs-border-color);
  background: var(--custom-onsurface-layer-2);
  color: var(--bs-body-color);
  font-family: var(--bs-font-sans-serif);
  font-size: 13px;
  font-weight: 600;
  padding: 11px 16px;
  border-radius: var(--bs-border-radius);
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  transition: background .15s ease, border-color .15s ease, color .15s ease;
}

.pm-modal__btn--primary {
  background: var(--pm-modal-accent);
  border-color: var(--pm-modal-accent);
  color: var(--bs-body-bg);
  box-shadow: 0 8px 22px -10px color-mix(in srgb, var(--pm-modal-accent) 70%, transparent);
}

.pm-modal__btn--primary:hover {
  background: color-mix(in srgb, var(--pm-modal-accent) 88%, white);
}

.pm-modal__btn--danger {
  background: var(--bs-danger);
  border-color: var(--bs-danger);
  color: #fff;
  box-shadow: 0 8px 22px -10px color-mix(in srgb, var(--bs-danger) 60%, transparent);
}

.pm-modal__btn--danger:hover {
  background: color-mix(in srgb, var(--bs-danger) 85%, white);
}

.pm-modal__btn--ghost {
  background: transparent;
  color: var(--bs-body-color);
}

.pm-modal__btn--ghost:hover {
  background: var(--custom-onsurface-layer-3);
  color: var(--bs-heading-color);
}

/* Top up */

.pm-topup__intro {
  margin-bottom: 24px;
}

.pm-topup__intro h3,
.pm-usage__intro h3 {
  font-family: var(--bs-font-sans-serif);
  font-weight: 600;
  font-size: 24px;
  letter-spacing: -0.02em;
  margin: 0 0 4px;
}

.pm-topup__intro p,
.pm-usage__intro p {
  margin: 0;
  font-size: 13px;
  color: var(--bs-body-color);
}

.pm-topup__grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 16px;
}

.pm-topup__card {
  position: relative;
  text-align: left;
  padding: 22px 22px 18px;
  border-radius: var(--bs-border-radius-lg);
  background: var(--custom-onsurface-layer-1);
  border: 0.5px solid var(--bs-border-color);
  color: var(--bs-heading-color);
  font-family: var(--bs-font-sans-serif);
  cursor: pointer;
  display: flex;
  flex-direction: column;
  gap: 6px;
  transition: border-color .2s ease;
}

.pm-topup__card:hover {
  background: var(--custom-onsurface-layer-2);
  border-color: color-mix(in srgb, var(--custom-primary) 50%, transparent);
}

.pm-topup__card.is-popular {
  border-color: color-mix(in srgb, var(--custom-primary) 50%, transparent);
  background: var(--custom-onsurface-layer-1);
}

.pm-topup__pop {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  align-self: flex-start;
  font-family: var(--bs-font-sans-serif);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.01em;
  color: var(--custom-primary);
  background: color-mix(in srgb, var(--custom-primary) 12%, transparent);
  border: 0.5px solid color-mix(in srgb, var(--custom-primary) 40%, transparent);
  padding: 4px 10px;
  border-radius: var(--bs-border-radius-sm);
}

.pm-topup__pop i { font-size: 9px; }

.pm-topup__price {
  font-family: var(--bs-font-sans-serif);
  font-weight: 700;
  font-size: 28px;
  line-height: 1;
  letter-spacing: -0.02em;
  color: var(--bs-heading-color);
  font-variant-numeric: tabular-nums;
}

.pm-topup__credits {
  display: flex;
  align-items: center;
  gap: 5px;
  margin-top: 2px;
}

.pm-topup__credits-num {
  font-family: var(--bs-font-sans-serif);
  font-weight: 500;
  font-size: 14px;
  font-variant-numeric: tabular-nums;
  color: var(--custom-primary);
}

.pm-topup__credits-unit {
  font-family: var(--bs-font-sans-serif);
  font-size: 13px;
  color: var(--custom-primary);
}

.pm-topup__perk {
  font-family: var(--bs-font-sans-serif);
  font-size: 12px;
  color: var(--bs-secondary-color);
}

.pm-topup__buy {
  margin-top: 12px;
  padding-top: 12px;
  border-top: 0.5px solid var(--bs-border-color);
  font-size: 12px;
  font-weight: 600;
  color: var(--bs-heading-color);
  display: inline-flex;
  align-items: center;
  gap: 8px;
}

.pm-topup__custom {
  margin-top: 22px;
  padding: 16px 20px;
  border: 0.5px dashed var(--bs-border-color);
  border-radius: var(--bs-border-radius-lg);
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 13px;
  color: var(--bs-body-color);
}

.pm-topup__custom a {
  color: var(--custom-primary);
  text-decoration: none;
  font-weight: 600;
}

.pm-topup__custom a:hover { text-decoration: underline; }

/* Usage */

.pm-usage__intro {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 24px;
  margin-bottom: 28px;
  flex-wrap: wrap;
}

.pm-usage__presets {
  margin-top: 12px;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
}

.pm-usage__preset {
  -moz-appearance: none;
       appearance: none;
  border: 0.5px solid var(--bs-border-color);
  background: transparent;
  color: var(--bs-body-color);
  border-radius: var(--bs-border-radius-sm);
  padding: 6px 11px;
  font-family: var(--bs-font-sans-serif);
  font-size: 12px;
  cursor: pointer;
  transition: border-color .18s ease, background .18s ease, color .18s ease;
}

.pm-usage__preset:hover {
  border-color: color-mix(in srgb, var(--custom-primary) 40%, transparent);
  color: var(--bs-heading-color);
}

.pm-usage__preset.is-active {
  background: color-mix(in srgb, var(--custom-primary) 16%, transparent);
  border-color: color-mix(in srgb, var(--custom-primary) 52%, transparent);
  color: var(--custom-primary);
}

.pm-usage__total {
  text-align: right;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 2px;
}

.pm-usage__total-num {
  font-family: var(--bs-font-sans-serif);
  font-weight: 600;
  font-size: 32px;
  line-height: 1;
  letter-spacing: -0.02em;
  color: var(--bs-heading-color);
  font-variant-numeric: tabular-nums;
}

.pm-usage__total-lbl {
  font-family: var(--bs-font-sans-serif);
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--bs-secondary-color);
}

.pm-usage__list {
  display: flex;
  flex-direction: column;
  gap: 18px;
}

.pm-usage__row {
  --pm-bar: var(--custom-primary);
  display: flex;
  flex-direction: column;
  gap: 8px;
  padding: 16px 18px;
  background: var(--custom-onsurface-layer-1);
  border: 0.5px solid var(--bs-border-color);
  border-radius: var(--bs-border-radius-lg);
  transition: border-color .2s ease;
}

.pm-usage__meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  flex-wrap: wrap;
}

.pm-usage__model {
  display: inline-flex;
  align-items: center;
  gap: 10px;
}

.pm-usage__swatch {
  width: 10px; height: 10px;
  border-radius: 3px;
  background: var(--pm-bar);
  box-shadow: 0 0 12px color-mix(in srgb, var(--pm-bar) 60%, transparent);
}

.pm-usage__name {
  font-size: 14px;
  font-weight: 600;
  color: var(--bs-heading-color);
}

.pm-usage__vendor {
  font-family: var(--bs-font-sans-serif);
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--bs-secondary-color);
  padding: 2px 7px;
  border: 0.5px solid var(--bs-border-color);
  border-radius: 4px;
}

.pm-usage__nums {
  display: inline-flex;
  align-items: baseline;
  gap: 8px;
}

.pm-usage__credits {
  font-family: var(--bs-font-sans-serif);
  font-weight: 600;
  font-size: 16px;
  letter-spacing: -0.015em;
  color: var(--bs-heading-color);
  font-variant-numeric: tabular-nums;
}

.pm-usage__credits-lbl {
  font-family: var(--bs-font-sans-serif);
  font-size: 12px;
  color: var(--bs-secondary-color);
}

.pm-usage__share {
  margin-left: 8px;
  font-family: var(--bs-font-sans-serif);
  font-size: 11px;
  color: var(--pm-bar);
  font-weight: 500;
}

.pm-usage__bar {
  height: 4px;
  width: 100%;
  border-radius: 999px;
  background: var(--bs-border-color);
  overflow: hidden;
}

.pm-usage__bar-fill {
  height: 100%;
  border-radius: 999px;
  background: var(--pm-bar);
  transition: width 1s cubic-bezier(0.22, 1, 0.36, 1);
}

.pm-usage__tokens {
  font-family: var(--bs-font-sans-serif);
  font-size: 12px;
  color: var(--bs-secondary-color);
  text-align: right;
  margin-bottom: 8px;
}

/* ─── Footer ─── */

.pm-footer {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  padding: 14px 28px;
  border-top: 0.5px solid var(--bs-border-color);
  font-size: 12px;
  color: var(--bs-body-color);
  flex-shrink: 0;
}

.pm-footer__vat {
  font-size: 11px;
  color: var(--bs-secondary-color);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  flex: 1;
  text-align: center;
}

.pm-footer__legal code {
  font-family: var(--bs-font-monospace);
  font-size: 11px;
  background: var(--custom-onsurface-layer-2);
  padding: 1px 6px;
  border-radius: var(--bs-border-radius-sm);
  color: var(--bs-body-color);
}

.pm-footer__links {
  display: flex;
  gap: 18px;
  white-space: nowrap;
  flex-shrink: 0;
}

.pm-footer__links a {
  color: var(--bs-body-color);
  text-decoration: none;
  transition: color .2s ease;
}

.pm-footer__links a:hover { color: var(--custom-primary); }

/* ─── Severity-aware shell tinting ─── */

.pm-shell--low,
.pm-shell--critical,
.pm-shell--empty {
  --pm-state: var(--bs-warning);
}

.pm-shell--critical { --pm-state: var(--bs-warning); }

.pm-shell--empty    { --pm-state: var(--bs-danger); }

/* Hero color shifts — only the headline number gets restyled now that the
   bar and ring are gone. */

.pm-hero--critical .pm-hero__num,
.pm-hero--empty .pm-hero__num {
  color: var(--pm-state);
}

/* ─── Alert banner ─── */

.pm-alert {
  --pm-state: var(--bs-warning);
  position: relative;
  z-index: 2;
  display: grid;
  grid-template-columns: auto 1fr auto;
  gap: 22px;
  align-items: center;
  padding: 22px 28px;
  margin: 18px 28px 0;
  border-radius: var(--bs-border-radius-lg);
  border: 1px solid color-mix(in srgb, var(--pm-state) 35%, transparent);
  background: color-mix(in srgb, var(--pm-state) 8%, var(--custom-onsurface-layer-1));
  overflow: hidden;
  animation: pm-alert-in .25s ease-out;
  flex-shrink: 0;
}

.pm-alert--critical { --pm-state: var(--bs-warning); }

.pm-alert--empty {
  --pm-state: var(--bs-danger);
  border-color: color-mix(in srgb, var(--pm-state) 50%, transparent);
  background: color-mix(in srgb, var(--pm-state) 10%, var(--custom-onsurface-layer-1));
}

@keyframes pm-alert-in {
  from { opacity: 0; transform: translateY(-6px); }
  to   { opacity: 1; transform: translateY(0); }
}

.pm-alert__glow {
  display: none;
}

.pm-alert--empty .pm-alert__glow { animation: pm-pulse-glow 2.4s ease-in-out infinite; }

@keyframes pm-pulse-glow {
  0%, 100% { opacity: 0.7; }
  50%      { opacity: 1; }
}

.pm-alert__icon {
  width: 48px; height: 48px;
  border-radius: var(--bs-border-radius-lg);
  background: color-mix(in srgb, var(--pm-state) 16%, transparent);
  border: 0.5px solid color-mix(in srgb, var(--pm-state) 45%, transparent);
  color: var(--pm-state);
  display: grid;
  place-items: center;
  font-size: 18px;
  flex-shrink: 0;
  position: relative;
  z-index: 1;
}

.pm-alert--empty .pm-alert__icon {
  animation: pm-icon-pulse 1.6s ease-in-out infinite;
}

@keyframes pm-icon-pulse {
  0%, 100% { box-shadow: 0 0 0 0 color-mix(in srgb, var(--pm-state) 35%, transparent); }
  50%      { box-shadow: 0 0 0 10px transparent; }
}

.pm-alert__body {
  position: relative;
  z-index: 1;
  min-width: 0;
}

.pm-alert__eyebrow {
  font-family: var(--bs-font-sans-serif);
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--pm-state);
  margin-bottom: 4px;
}

.pm-alert__title {
  font-family: var(--bs-font-sans-serif);
  font-weight: 600;
  font-size: 20px;
  letter-spacing: -0.02em;
  color: var(--bs-heading-color);
  line-height: 1.15;
}

.pm-alert__desc {
  margin: 6px 0 0;
  font-size: 13px;
  color: var(--bs-body-color);
  line-height: 1.55;
  max-width: 60ch;
}

.pm-alert__actions {
  display: flex;
  gap: 10px;
  flex-shrink: 0;
  position: relative;
  z-index: 1;
}

.pm-alert__btn {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  padding: 11px 18px;
  border-radius: var(--bs-border-radius);
  border: none;
  font-family: var(--bs-font-sans-serif);
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
  transition: background .2s ease, color .2s ease;
}

.pm-alert__btn--ghost {
  background: transparent;
  border: 1px solid var(--custom-border-light);
  color: var(--bs-body-color);
}

.pm-alert__btn--ghost:hover {
  background: var(--custom-onsurface-layer-2);
}

.pm-alert__btn--solid {
  background: var(--pm-state);
  color: #fff;
}

.pm-alert__btn--solid:hover {
  background: color-mix(in srgb, var(--pm-state) 88%, white);
}

/* ─── Dev scenario switcher ─── */

.pm-scenario {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 3px 4px 3px 10px;
  border-radius: var(--bs-border-radius-sm);
  border: 1px dashed var(--bs-border-color);
  background: var(--custom-onsurface-layer-1);
  font-family: var(--bs-font-sans-serif);
  font-size: 9px;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--bs-secondary-color);
}

.pm-scenario > i {
  font-size: 9px;
  margin-right: 4px;
  opacity: 0.6;
}

.pm-scenario__btn {
  background: none;
  border: none;
  padding: 4px 9px;
  border-radius: var(--bs-border-radius-sm);
  color: var(--bs-secondary-color);
  font: inherit;
  cursor: pointer;
  transition: color .15s, background .15s;
}

.pm-scenario__btn:hover { color: var(--bs-body-color); }

.pm-scenario__btn.is-active {
  background: color-mix(in srgb, var(--custom-primary) 15%, transparent);
  color: var(--custom-primary);
}

/* ─── Responsive ─── */

@media (max-width: 720px) {
  .pm-backdrop { padding: 0; }
  .pm-shell { border-radius: 0; max-height: 100vh; }
  .pm-hero { grid-template-columns: 1fr; padding: 24px; gap: 24px; }
  .pm-hero__right { flex-direction: row; }
  .pm-main { padding: 22px; }
  .pm-topbar { padding: 14px 20px; flex-wrap: wrap; gap: 10px; }
  .pm-nav { padding: 0 16px; overflow-x: auto; }
  .pm-alert { grid-template-columns: 1fr; gap: 14px; margin: 14px 16px 0; padding: 18px; }
  .pm-alert__icon { width: 40px; height: 40px; font-size: 16px; }
  .pm-alert__actions { flex-direction: column; }
  .pm-alert__btn { justify-content: center; }
  .pm-scenario { display: none; }
  .pm-scenario-stack { display: none; }
  .pm-beta-alert { margin: 14px 16px 0; padding: 24px; }
  .pm-beta-alert__title { font-size: 22px; }
  .pm-beta-alert__actions { flex-direction: column; align-items: stretch; }
  .pm-beta-alert__btn { justify-content: center; }
}

/* ─── Dev scenario stack (two switcher rows) ─── */

.pm-scenario-stack {
  display: flex;
  flex-direction: column;
  gap: 6px;
  margin-left: auto;
  margin-right: 12px;
}

.pm-scenario-stack .pm-scenario { margin-left: 0; }

/* ─── Plan lifecycle alert (paid) — extends .pm-alert ─── */

.pm-alert--plan-expiring {
  --pm-state: var(--bs-warning);
}

.pm-alert--plan-expired {
  --pm-state: var(--bs-danger);
}

.pm-alert__meta {
  display: inline-block;
  margin-left: 6px;
  color: var(--bs-body-color);
  font-family: var(--bs-font-sans-serif);
  font-size: 11px;
  text-transform: uppercase;
}

/* ─── Beta transition alert (special, gracious) ─── */

.pm-beta-alert {
  position: relative;
  margin: 14px 28px 0;
  padding: 22px 28px;
  border-radius: var(--bs-border-radius-lg);
  overflow: hidden;
  isolation: isolate;
  background: var(--custom-onsurface-layer-1);
  border: 1px solid var(--bs-border-color);
  flex-shrink: 0;
}

.pm-beta-alert--expired {
  border-color: color-mix(in srgb, var(--bs-warning) 45%, transparent);
}

.pm-beta-alert__aurora {
  display: none;
}

.pm-beta-alert__sparkles {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: -1;
}

.pm-beta-alert__sparkles span {
  position: absolute;
  width: 4px;
  height: 4px;
  border-radius: 50%;
  background: #fff;
  opacity: 0;
  animation: pm-sparkle 4.2s ease-in-out infinite;
  box-shadow: 0 0 8px 2px rgba(255, 255, 255, 0.6);
}

.pm-beta-alert__sparkles span:nth-child(1) { top: 18%; left: 12%; animation-delay: 0s; }

.pm-beta-alert__sparkles span:nth-child(2) { top: 70%; left: 28%; animation-delay: 1.1s; }

.pm-beta-alert__sparkles span:nth-child(3) { top: 32%; left: 78%; animation-delay: 2.2s; }

.pm-beta-alert__sparkles span:nth-child(4) { top: 80%; left: 88%; animation-delay: 3.1s; }

@keyframes pm-sparkle {
  0%, 100% { opacity: 0; transform: scale(0.6); }
  50%      { opacity: 0.9; transform: scale(1.2); }
}

.pm-beta-alert__inner {
  position: relative;
  display: flex;
  flex-direction: column;
  gap: 10px;
  max-width: 680px;
}

.pm-beta-alert__badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  align-self: flex-start;
  padding: 6px 12px;
  border-radius: var(--bs-border-radius-sm);
  background: color-mix(in srgb, var(--custom-primary) 18%, transparent);
  border: 1px solid color-mix(in srgb, var(--custom-primary) 40%, transparent);
  color: color-mix(in srgb, var(--custom-primary) 90%, white);
  font-family: var(--bs-font-sans-serif);
  font-size: 11px;
  letter-spacing: 0.06em;
  text-transform: uppercase;
}

.pm-beta-alert--expired .pm-beta-alert__badge {
  background: color-mix(in srgb, var(--bs-warning) 18%, transparent);
  border-color: color-mix(in srgb, var(--bs-warning) 40%, transparent);
  color: color-mix(in srgb, var(--bs-warning) 90%, white);
}

.pm-beta-alert__badge i { font-size: 12px; }

.pm-beta-alert__title {
  margin: 0;
  font-family: var(--bs-font-sans-serif);
  font-weight: 500;
  font-size: 24px;
  line-height: 1.15;
  letter-spacing: -0.02em;
  color: var(--bs-heading-color);
}

.pm-beta-alert__lede {
  margin: 0;
  font-size: 14.5px;
  line-height: 1.5;
  color: var(--bs-heading-color);
}

.pm-beta-alert__body {
  margin: 0;
  font-size: 13px;
  line-height: 1.55;
  color: var(--bs-body-color);
  max-width: 600px;
}

.pm-beta-alert__actions {
  display: flex;
  gap: 10px;
  margin-top: 4px;
  flex-wrap: wrap;
}

.pm-beta-alert__btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 11px 18px;
  border-radius: var(--bs-border-radius);
  font-family: var(--bs-font-sans-serif);
  font-weight: 500;
  font-size: 13.5px;
  letter-spacing: 0.01em;
  cursor: pointer;
  transition: background 0.2s ease;
  border: 1px solid transparent;
}

.pm-beta-alert__btn--primary {
  background: var(--custom-primary);
  color: var(--bs-body-bg);
}

.pm-beta-alert__btn--primary:hover {
  background: color-mix(in srgb, var(--custom-primary) 88%, white);
}

.pm-beta-alert__btn--ghost {
  background: color-mix(in srgb, var(--bs-body-color) 5%, transparent);
  color: var(--bs-body-color);
  border-color: var(--bs-border-color);
}

.pm-beta-alert__btn--ghost:hover {
  background: color-mix(in srgb, var(--bs-body-color) 10%, transparent);
  border-color: var(--bs-border-color);
}

.pm-beta-alert__btn i { font-size: 12px; }

/* ─── Loading skeleton ─── */

.pm-skeleton {
  position: relative;
  z-index: 2;
  padding: 28px 36px;
  display: flex;
  flex-direction: column;
  gap: 26px;
}

.pm-skeleton__hero {
  display: flex;
  flex-direction: column;
  gap: 12px;
  padding-bottom: 22px;
  border-bottom: 0.5px solid var(--bs-border-color);
}

.pm-skeleton__nav {
  display: flex;
  gap: 18px;
  padding: 4px 0;
}

.pm-skeleton__cards {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
}

.pm-skeleton__card {
  display: flex;
  flex-direction: column;
  gap: 12px;
  padding: 22px;
  border-radius: var(--bs-border-radius-lg);
  background: rgba(255, 255, 255, 0.02);
  border: 1px solid var(--bs-border-color);
}

.pm-skel {
  position: relative;
  overflow: hidden;
  border-radius: 6px;
  background: rgba(255, 255, 255, 0.04);
}

.pm-skel::after {
  content: '';
  position: absolute;
  inset: 0;
  transform: translateX(-100%);
  background: linear-gradient(
    90deg,
    transparent 0%,
    rgba(255, 255, 255, 0.06) 50%,
    transparent 100%
  );
  animation: pm-shimmer 1.4s ease-in-out infinite;
}

@keyframes pm-shimmer {
  100% { transform: translateX(100%); }
}

.pm-skel--eyebrow { width: 100px; height: 10px; }

.pm-skel--num     { width: 220px; height: 38px; border-radius: 8px; }

.pm-skel--sub     { width: 320px; height: 12px; }

.pm-skel--bar     { width: 100%; height: 6px; border-radius: 999px; max-width: 480px; }

.pm-skel--tab     { width: 80px; height: 28px; border-radius: 8px; }

.pm-skel--title   { width: 60%; height: 18px; }

.pm-skel--line    { width: 100%; height: 11px; }

.pm-skel--short   { width: 70%; }

.pm-skel--price   { width: 50%; height: 28px; border-radius: 6px; margin: 8px 0 4px; }

.pm-skel--btn     { width: 100%; height: 38px; border-radius: 10px; margin-top: auto; }

/* ─── Error / empty state ─── */

.pm-empty {
  position: relative;
  z-index: 2;
  margin: 32px 36px;
  padding: 48px 32px;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 14px;
  border: 1px solid var(--bs-border-color);
  border-radius: var(--bs-border-radius-lg);
  background: var(--custom-onsurface-layer-1);
}

.pm-empty__icon {
  width: 56px;
  height: 56px;
  border-radius: 50%;
  display: grid;
  place-items: center;
  font-size: 22px;
  color: var(--bs-warning);
  background: color-mix(in srgb, var(--bs-warning) 12%, transparent);
  border: 1px solid color-mix(in srgb, var(--bs-warning) 30%, transparent);
}

.pm-empty__title {
  font-family: var(--bs-font-sans-serif);
  font-weight: 500;
  font-size: 20px;
  letter-spacing: -0.02em;
  color: var(--bs-heading-color);
}

.pm-empty__body {
  margin: 0;
  max-width: 480px;
  font-size: 13.5px;
  line-height: 1.55;
  color: var(--bs-body-color);
}

.pm-empty__actions {
  display: flex;
  gap: 10px;
  margin-top: 8px;
  flex-wrap: wrap;
  justify-content: center;
}

.pm-empty__btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 10px 18px;
  border-radius: var(--bs-border-radius);
  font-family: var(--bs-font-sans-serif);
  font-weight: 500;
  font-size: 13px;
  cursor: pointer;
  text-decoration: none;
  border: 1px solid transparent;
  transition: background 0.2s ease, border-color 0.2s ease;
}

.pm-empty__btn--primary {
  background: var(--custom-primary);
  color: var(--bs-body-bg);
}

.pm-empty__btn--primary:hover {
  background: color-mix(in srgb, var(--custom-primary) 88%, white);
}

.pm-empty--error .pm-empty__icon {
  color: var(--bs-danger);
  background: color-mix(in srgb, var(--bs-danger) 12%, transparent);
  border-color: color-mix(in srgb, var(--bs-danger) 30%, transparent);
}

.pm-empty__btn--ghost {
  background: color-mix(in srgb, var(--bs-body-color) 5%, transparent);
  color: var(--bs-body-color);
  border-color: var(--bs-border-color);
}

.pm-empty__btn--ghost:hover {
  background: color-mix(in srgb, var(--bs-body-color) 10%, transparent);
  border-color: var(--bs-border-color);
}

.pm-empty__btn i { font-size: 11px; }

/* ─── Reduced motion ─── */

@media (prefers-reduced-motion: reduce) {
  .pm-beta-alert__aurora,
  .pm-beta-alert__sparkles span,
  .pm-skel::after,
  .pm-atmosphere__orb,
  .pm-hero__bar-fill {
    animation: none !important;
    transition: none !important;
  }
  .pm-beta-alert__sparkles span { opacity: 0.6; }
}

/* ─── Checkout result screen ─── */

.pm-result {
  position: relative;
  z-index: 2;
  margin: 28px 36px;
  padding: 56px 40px 44px;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 14px;
  border-radius: var(--bs-border-radius-lg);
  border: 1px solid var(--bs-border-color);
  background: var(--bs-body-bg);
  overflow: hidden;
  isolation: isolate;
}

/* Color tokens per result kind */

.pm-result--processing { --pm-result-color: var(--bs-info); }

.pm-result--success    { --pm-result-color: var(--custom-primary); }

.pm-result--closed     { --pm-result-color: var(--bs-secondary-color); }

.pm-result--error      { --pm-result-color: var(--bs-danger); }

.pm-result__halo {
  display: none;
}

.pm-result__icon {
  position: relative;
  width: 72px;
  height: 72px;
  border-radius: 50%;
  display: grid;
  place-items: center;
  font-size: 28px;
  color: var(--pm-result-color);
  background: color-mix(in srgb, var(--pm-result-color) 14%, transparent);
  border: 1px solid color-mix(in srgb, var(--pm-result-color) 35%, transparent);
  box-shadow:
    0 0 0 8px color-mix(in srgb, var(--pm-result-color) 8%, transparent),
    0 16px 48px -16px color-mix(in srgb, var(--pm-result-color) 60%, transparent);
}

.pm-result__icon--success {
  animation: pm-success-pop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) backwards;
}

@keyframes pm-success-pop {
  0%   { transform: scale(0.5); opacity: 0; }
  60%  { transform: scale(1.1); opacity: 1; }
  100% { transform: scale(1); }
}

.pm-result__eyebrow {
  font-family: var(--bs-font-sans-serif);
  font-size: 11px;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: color-mix(in srgb, var(--pm-result-color) 90%, white);
}

.pm-result__title {
  margin: 4px 0 0;
  font-family: var(--bs-font-sans-serif);
  font-weight: 500;
  font-size: 26px;
  line-height: 1.2;
  letter-spacing: -0.02em;
  color: var(--bs-heading-color);
  max-width: 540px;
}

.pm-result__body {
  margin: 0;
  max-width: 520px;
  font-size: 14px;
  line-height: 1.55;
  color: var(--bs-body-color);
}

.pm-result__detail {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  margin-top: 4px;
  padding: 10px 16px;
  border-radius: 10px;
  background: color-mix(in srgb, var(--pm-result-color) 10%, transparent);
  border: 1px solid color-mix(in srgb, var(--pm-result-color) 25%, transparent);
  font-size: 13px;
  color: var(--bs-body-color);
  max-width: 520px;
}

.pm-result__detail i {
  color: var(--pm-result-color);
  font-size: 12px;
}

.pm-result__txn {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  margin-top: 6px;
  padding: 6px 12px;
  border-radius: 8px;
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid var(--bs-border-color);
}

.pm-result__txn-label {
  font-family: var(--bs-font-sans-serif);
  font-size: 10px;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--bs-secondary-color);
}

.pm-result__txn-id {
  font-family: var(--bs-font-monospace);
  font-size: 12px;
  color: var(--bs-body-color);
  background: none;
  padding: 0;
}

.pm-result__actions {
  display: flex;
  gap: 10px;
  margin-top: 10px;
  flex-wrap: wrap;
  justify-content: center;
}

.pm-result__btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 11px 20px;
  border-radius: var(--bs-border-radius);
  font-family: var(--bs-font-sans-serif);
  font-weight: 500;
  font-size: 13.5px;
  cursor: pointer;
  text-decoration: none;
  border: 1px solid transparent;
  transition: background 0.2s ease, border-color 0.2s ease;
}

.pm-result__btn--primary {
  background: var(--pm-result-color);
  color: var(--bs-body-bg);
}

.pm-result__btn--primary:hover {
  background: color-mix(in srgb, var(--pm-result-color) 88%, white);
}

.pm-result__btn--ghost {
  background: color-mix(in srgb, var(--bs-body-color) 5%, transparent);
  color: var(--bs-body-color);
  border-color: var(--bs-border-color);
}

.pm-result__btn--ghost:hover {
  background: color-mix(in srgb, var(--bs-body-color) 10%, transparent);
  border-color: var(--bs-border-color);
}

.pm-result__btn i { font-size: 12px; }

@media (max-width: 720px) {
  .pm-result {
    margin: 14px 16px;
    padding: 40px 22px 30px;
  }
  .pm-result__title { font-size: 22px; }
  .pm-result__actions { flex-direction: column; align-self: stretch; }
  .pm-result__btn { justify-content: center; }
}

/* Reduced-motion additions for result screen */

@media (prefers-reduced-motion: reduce) {
  .pm-result__halo,
  .pm-result__icon--success,
  .fa-spin {
    animation: none !important;
  }
}

/* ─────────────────────────────────────────────────────────────────────────────
   Sign-in prompt — shown when the user opens the panel without an account.
   Mirrors the beta-alert look (aurora glow + atmospheric inner card) but
   leans warmer to feel inviting rather than transactional.
   ───────────────────────────────────────────────────────────────────────── */

.pm-signin {
  position: relative;
  margin: 24px 28px 32px;
  border-radius: var(--bs-border-radius);
  background: var(--custom-onsurface-layer-1);
  border: 1px solid var(--bs-border-color);
  overflow: hidden;
}

.pm-signin__halo {
  display: none;
}

.pm-signin__inner {
  position: relative;
  z-index: 1;
  padding: 36px 40px 32px;
  display: flex;
  flex-direction: column;
  gap: 18px;
  text-align: left;
}

.pm-signin__badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  align-self: flex-start;
  padding: 6px 12px;
  border-radius: var(--bs-border-radius-sm);
  background: var(--custom-onsurface-layer-2);
  border: 1px solid var(--bs-border-color);
  color: var(--bs-body-color);
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 0.04em;
  text-transform: uppercase;
}

.pm-signin__badge i { font-size: 11px; }

.pm-signin__title {
  margin: 4px 0 0;
  font-size: 22px;
  font-weight: 700;
  color: var(--bs-heading-color);
  line-height: 1.2;
}

.pm-signin__lede {
  margin: 0;
  max-width: 60ch;
  color: var(--bs-body-color);
  font-size: 13px;
  line-height: 1.55;
}

.pm-signin__perks {
  list-style: none;
  margin: 6px 0 0;
  padding: 0;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10px 24px;
}

.pm-signin__perks li {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 13px;
  color: var(--bs-body-color);
}

.pm-signin__perks i {
  width: 22px;
  height: 22px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--bs-border-radius-sm);
  background: var(--custom-onsurface-layer-2);
  color: var(--custom-primary);
  font-size: 11px;
}

.pm-signin__actions {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin-top: 8px;
}

.pm-signin__btn {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 11px 18px;
  border-radius: var(--bs-border-radius);
  font-size: 14px;
  font-weight: 600;
  border: 1px solid transparent;
  cursor: pointer;
  transition: background 160ms ease, border-color 160ms ease, opacity 160ms ease;
}

.pm-signin__btn:disabled { opacity: 0.6; cursor: progress; transform: none; }

.pm-signin__btn--primary {
  background: var(--custom-primary);
  color: var(--bs-body-bg);
  border-color: var(--custom-primary);
}

.pm-signin__btn--primary:hover {
  background: color-mix(in srgb, var(--custom-primary) 88%, white);
}

.pm-signin__btn--github {
  background: var(--custom-onsurface-layer-2);
  color: var(--bs-body-color);
  border-color: var(--bs-border-color);
}

.pm-signin__btn--github:hover { background: var(--custom-onsurface-layer-3); }

.pm-signin__btn--google {
  background: var(--custom-onsurface-layer-2);
  color: var(--bs-body-color);
  border-color: var(--bs-border-color);
}

.pm-signin__btn--google:hover { background: var(--custom-onsurface-layer-3); }

.pm-signin__btn--ghost {
  background: transparent;
  color: var(--bs-body-color);
  border-color: var(--bs-border-color);
}

.pm-signin__btn--ghost:hover { background: var(--custom-onsurface-layer-2); }

.pm-signin__legal {
  margin: 6px 0 0;
  font-size: 12px;
  color: var(--bs-body-color);
}

.pm-signin__legal a {
  color: var(--bs-body-color);
  text-decoration: underline;
  text-underline-offset: 2px;
}

.pm-signin__legal a:hover { color: var(--bs-heading-color); }

@media (max-width: 720px) {
  .pm-signin { margin: 16px; }
  .pm-signin__inner { padding: 28px 24px 24px; }
  .pm-signin__title { font-size: 22px; }
  .pm-signin__perks { grid-template-columns: 1fr; }
  .pm-signin__actions { flex-direction: column; align-items: stretch; }
  .pm-signin__btn { justify-content: center; }
}

@media (prefers-reduced-motion: reduce) {
  .pm-signin__halo { animation: none; }
}

/* ─────────────────────────────────────────────────────────────────────────────
   Email verification gate — reuses the .pm-signin shell (halo, badge,
   typography, buttons) and only adds the bits that don't exist there:
   the email input, the OTP grid framing, and the inline alert pills.
   ───────────────────────────────────────────────────────────────────────── */

.pm-verify__field {
  display: flex;
  flex-direction: column;
  gap: 6px;
  margin-top: 4px;
}

.pm-verify__label {
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  color: var(--bs-body-color);
  margin: 0;
}

.pm-verify__input {
  width: 100%;
  padding: 10px 12px;
  border-radius: var(--bs-border-radius);
  background: var(--bs-body-bg);
  border: 1px solid var(--bs-border-color);
  color: var(--bs-body-color);
  font-size: 14px;
  font-family: var(--bs-font-sans-serif);
  line-height: 1.4;
  transition: border-color 160ms ease, box-shadow 160ms ease;
}

.pm-verify__input::-moz-placeholder {
  color: var(--bs-secondary-color);
}

.pm-verify__input::placeholder {
  color: var(--bs-secondary-color);
}

.pm-verify__input:focus {
  outline: none;
  border-color: var(--custom-primary);
  box-shadow: 0 0 0 3px rgba(var(--custom-primary-rgb), 0.18);
}

.pm-verify__input:disabled {
  opacity: 0.6;
  cursor: not-allowed;
}

.pm-verify__email {
  color: var(--bs-heading-color);
  font-weight: 600;
  word-break: break-all;
}

.pm-verify__alert {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  padding: 10px 14px;
  border-radius: var(--bs-border-radius);
  font-size: 13px;
  line-height: 1.5;
}

.pm-verify__alert i {
  margin-top: 2px;
  flex: 0 0 auto;
}

.pm-verify__alert--error {
  background: color-mix(in srgb, var(--bs-danger) 10%, transparent);
  border: 1px solid color-mix(in srgb, var(--bs-danger) 30%, transparent);
  color: var(--bs-danger);
}

.pm-verify__alert--info {
  background: color-mix(in srgb, var(--bs-info) 10%, transparent);
  border: 1px solid color-mix(in srgb, var(--bs-info) 25%, transparent);
  color: var(--bs-info);
}

.pm-verify__otp {
  display: flex;
  justify-content: center;
  margin: 4px 0 4px;
}

.pm-verify__otp .login-modal-otp-digit {
  background: var(--bs-body-bg);
  border-color: var(--bs-border-color);
  color: var(--bs-body-color);
}

.pm-verify__otp .login-modal-otp-digit:focus {
  border-color: var(--custom-primary);
  box-shadow: 0 0 0 3px rgba(var(--custom-primary-rgb), 0.18);
}

.pm-verify__otp .login-modal-otp-digit.has-value {
  border-color: var(--custom-primary);
  background: color-mix(in srgb, var(--custom-primary) 12%, transparent);
}

/* ─────────────────────────────────────────────────────────────────────────────
   QuotasPanel — per-(provider, model) usage caps tied to the active plan.
   Sits right under the Hero. Visual language matches the "editorial cosmos":
   thin lines, mono eyebrow, glass cards, tonal progress bars.
   ───────────────────────────────────────────────────────────────────────── */

.pm-quotas {
  position: relative;
  z-index: 2;
  padding: 22px 36px 26px;
  border-bottom: 0.5px solid var(--bs-border-color);
  flex-shrink: 0;
}

.pm-quotas__head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16px;
  margin-bottom: 16px;
}

.pm-quotas__eyebrow {
  font-family: var(--bs-font-sans-serif);
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--bs-secondary-color);
  margin-bottom: 6px;
}

.pm-quotas__title {
  font-family: var(--bs-font-sans-serif);
  font-weight: 500;
  font-size: 18px;
  letter-spacing: -0.01em;
  color: var(--bs-heading-color);
  margin: 0;
}

.pm-quotas__hint {
  font-family: var(--bs-font-sans-serif);
  font-size: 10.5px;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--bs-secondary-color);
}

.pm-quotas__list {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 12px;
}

.pm-quota {
  position: relative;
  display: flex;
  flex-direction: column;
  gap: 10px;
  padding: 14px 16px;
  border: 1px solid var(--bs-border-color);
  border-radius: var(--bs-border-radius);
  background: var(--custom-onsurface-layer-1);
  transition: border-color 120ms ease, background 120ms ease;
}

.pm-quota--warn {
  border-color: color-mix(in srgb, var(--bs-warning) 35%, transparent);
}

.pm-quota--crit {
  border-color: color-mix(in srgb, var(--bs-danger) 40%, transparent);
  background: color-mix(in srgb, var(--bs-danger) 8%, transparent);
}

.pm-quota--unlimited {
  border-color: color-mix(in srgb, var(--custom-primary) 30%, transparent);
}

.pm-quota__head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12px;
}

.pm-quota__label {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.pm-quota__name {
  font-family: var(--bs-font-sans-serif);
  font-weight: 500;
  font-size: 14px;
  color: var(--bs-heading-color);
  letter-spacing: -0.005em;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.pm-quota__period {
  font-family: var(--bs-font-sans-serif);
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--bs-secondary-color);
  margin-top: 2px;
}

.pm-quota__counts {
  display: flex;
  align-items: baseline;
  gap: 3px;
  font-variant-numeric: tabular-nums;
  font-family: var(--bs-font-sans-serif);
  font-size: 12.5px;
  color: var(--bs-heading-color);
  white-space: nowrap;
}

.pm-quota__used {
  color: var(--bs-heading-color);
  font-weight: 600;
}

.pm-quota__sep {
  color: var(--bs-secondary-color);
}

.pm-quota__cap {
  color: var(--bs-secondary-color);
}

.pm-quota__badge {
  font-family: var(--bs-font-sans-serif);
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  padding: 3px 8px;
  border-radius: var(--bs-border-radius-sm);
  border: 0.5px solid currentColor;
  white-space: nowrap;
}

.pm-quota__badge--unlimited {
  color: var(--custom-primary);
  background: color-mix(in srgb, var(--custom-primary) 10%, transparent);
}

.pm-quota__bar {
  position: relative;
  height: 4px;
  border-radius: 999px;
  background: var(--bs-border-color);
  overflow: hidden;
}

.pm-quota__bar-fill {
  height: 100%;
  border-radius: inherit;
  background: var(--custom-primary);
  transition: width 200ms ease;
}

.pm-quota--warn .pm-quota__bar-fill {
  background: var(--bs-warning);
}

.pm-quota--crit .pm-quota__bar-fill {
  background: var(--bs-danger);
}

.pm-quota__foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
}

.pm-quota__reset {
  font-family: var(--bs-font-sans-serif);
  font-size: 10.5px;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--bs-secondary-color);
}

.pm-quota--crit .pm-quota__reset {
  color: var(--bs-danger);
}

.pm-quota__cta {
  border: 1px solid color-mix(in srgb, var(--bs-danger) 40%, transparent);
  background: color-mix(in srgb, var(--bs-danger) 10%, transparent);
  color: var(--bs-danger);
  font-family: var(--bs-font-sans-serif);
  font-size: 11px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  padding: 4px 10px;
  border-radius: var(--bs-border-radius-sm);
  cursor: pointer;
  transition: background 120ms ease;
}

.pm-quota__cta:hover {
  background: color-mix(in srgb, var(--bs-danger) 20%, transparent);
}

/* ── Quotas: collapsed/expanded toggle + "+N more" tile ─────────────── */

.pm-quotas__head-right {
  display: flex;
  align-items: center;
  gap: 14px;
  flex-wrap: wrap;
  justify-content: flex-end;
}

.pm-quotas__toggle {
  -moz-appearance: none;
       appearance: none;
  background: transparent;
  border: 1px solid var(--bs-border-color);
  color: var(--bs-heading-color);
  font-family: var(--bs-font-sans-serif);
  font-size: 10.5px;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  padding: 6px 12px;
  border-radius: var(--bs-border-radius);
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  transition: background 120ms ease, border-color 120ms ease, color 120ms ease;
  white-space: nowrap;
}

.pm-quotas__toggle:hover {
  background: var(--custom-onsurface-layer-2);
  border-color: var(--custom-border-light);
  color: var(--bs-heading-color);
}

.pm-quotas__toggle i {
  font-size: 9px;
  opacity: 0.85;
}

.pm-quota--more {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: flex-start;
  gap: 6px;
  border: 1px dashed var(--bs-border-color);
  background: transparent;
  color: var(--bs-heading-color);
  padding: 18px 18px;
  border-radius: var(--bs-border-radius-lg);
  cursor: pointer;
  text-align: left;
  font: inherit;
  transition: background 120ms ease, border-color 120ms ease, transform 120ms ease;
  min-height: 132px;
}

.pm-quota--more:hover {
  background: var(--custom-onsurface-layer-2);
  border-color: var(--custom-border-light);
}

.pm-quota--more:active {
  transform: translateY(1px);
}

.pm-quota__more-num {
  font-family: var(--bs-font-sans-serif);
  font-size: 28px;
  font-weight: 600;
  letter-spacing: -0.01em;
  color: var(--bs-heading-color);
  line-height: 1;
}

.pm-quota__more-label {
  font-family: var(--bs-font-sans-serif);
  font-size: 10.5px;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--bs-secondary-color);
}

.pm-quota__more-cta {
  margin-top: auto;
  font-family: var(--bs-font-sans-serif);
  font-size: 10.5px;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--bs-heading-color);
  display: inline-flex;
  align-items: center;
  gap: 6px;
}

.pm-quota__more-cta i {
  font-size: 9px;
}

/* When collapsed, drop the auto-fill grid down to a tighter 2-up layout
   so the preview reads as a summary, not a half-empty grid. */

.pm-quotas--collapsed .pm-quotas__list {
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
}

/* ── Upgrade promo banner ───────────────────────────────────────────── */

.pm-promo {
  position: relative;
  display: flex;
  align-items: center;
  gap: 24px;
  margin: 1rem;
  padding: 16px 20px;
  border: 1px solid var(--bs-border-color);
  border-radius: var(--bs-border-radius);
  background: var(--custom-onsurface-layer-1);
  overflow: hidden;
}

.pm-promo__glow { display: none; }

.pm-promo__body {
  flex: 1;
  min-width: 0;
}

.pm-promo__eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-family: var(--bs-font-sans-serif);
  font-size: 11px;
  font-weight: 600;
  text-transform: uppercase;
